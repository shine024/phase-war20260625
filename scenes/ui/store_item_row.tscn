[gd_scene format=3 uid="uid://store_item_row_tpl"]

[node name="StoreItemRow" type="PanelContainer"]
size_flags_horizontal = 3

[node name="RowMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 8
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 8

[node name="RowHBox" type="HBoxContainer" parent="RowMargin"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="InfoVBox" type="VBoxContainer" parent="RowMargin/RowHBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 2

[node name="NameLabel" type="Label" parent="RowMargin/RowHBox/InfoVBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 13
text = "蓝图名称  × 1 蓝图"

[node name="InfoLabel" type="Label" parent="RowMargin/RowHBox/InfoVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.85, 0.95, 0.9)
theme_override_font_sizes/font_size = 11
text = ""
visible = false

[node name="BaseAttrsLabel" type="Label" parent="RowMargin/RowHBox/InfoVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.5, 0.7, 0.85, 0.8)
theme_override_font_sizes/font_size = 10
text = ""
visible = false

[node name="CombatLabel" type="Label" parent="RowMargin/RowHBox/InfoVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.6, 0.9, 0.6, 0.85)
theme_override_font_sizes/font_size = 10
autowrap_mode = 2
text = ""
visible = false

[node name="DescLabel" type="Label" parent="RowMargin/RowHBox/InfoVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.6, 0.7, 0.8, 0.75)
theme_override_font_sizes/font_size = 10
